# ---------------------------------------------------------------------------
# MFLH Collective — environment variables
# Copy to .env.local for local dev. Set the same vars in Netlify dashboard
# (Site settings → Environment variables) for production.
# ---------------------------------------------------------------------------

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY. Powers the admin portal and form
# inserts. Never expose this to the browser / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for metadata / absolute links)
NEXT_PUBLIC_SITE_URL=https://mflhcollective.com

# Manager PIN that gates the staff Hours & Payroll report (server-side only).
# Defaults to 0000 if unset. Set a real value in production.
STAFF_REPORT_PIN=

# ---------------------------------------------------------------------------
# Square — powers the merch storefront (catalog + checkout) so merch and the
# in-gym coffee bar share one Square dashboard. When unset, the shop falls
# back to the Supabase products table and checkout is disabled.
# From the Square Developer dashboard → your application + location.
# ---------------------------------------------------------------------------
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production   # or "sandbox" for testing
# SQUARE_VERSION=2025-01-23     # optional API version override

# ---------------------------------------------------------------------------
# Strava (read-only) — syncs the Move Fast Lift Heavy Run Club's upcoming
# group events + routes to the public /run-club page. When unset, the page
# shows a "join us on Strava" fallback. From the Strava API application; the
# refresh token must belong to a club member with read scope.
# ---------------------------------------------------------------------------
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_CLUB_ID=
